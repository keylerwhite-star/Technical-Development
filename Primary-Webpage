                <div className="module-header-title">{module.title}</div>
                <div className="module-header-sub">{module.subtitle}</div>
                <div className="module-header-dur" style={{ background: track.accent, color: track.color, border: `1px solid ${track.color}33` }}>
                  {module.duration} · 2 days/week · ~6 hrs/week
                </div>
              </div>

              <div className="weeks-container">
                {module.weeks.map(w => {
                  const isOpen = expandedWeek === w.week;
                  const hasProject = !!w.project;
                  return (
                    <div key={w.week} className={`week-card ${isOpen ? (activeTrack === "space" ? "open-space" : "open-air") : ""}`}>
                      <div className="week-header" onClick={() => setExpandedWeek(isOpen ? null : w.week)}>
                        <div className="week-num" style={{ color: track.color }}>WK {String(w.week).padStart(2, "0")}</div>
                        <div className="week-theme">{w.theme}</div>
                        {hasProject && <div className="project-dot" style={{ background: track.color }} title="Project checkpoint" />}
                        <div className={`chevron ${isOpen ? "open" : ""}`}>▼</div>
                      </div>

                      {isOpen && (
                        <div className="week-body">
                          <div className="activity-row">
                            <div className="activity-day" style={{ color: track.color }}>WEEKDAY<br /><span style={{ color: "#444", fontSize: "8px" }}>2 HRS</span></div>
                            <div className="activity-type" style={{ background: `${track.color}15`, color: track.color, border: `1px solid ${track.color}33` }}>{w.weekday.label.toUpperCase()}</div>
                            <div className="activity-content">{w.weekday.content}</div>
                          </div>
                          <div className="activity-row">
                            <div className="activity-day" style={{ color: track.color }}>WEEKEND<br /><span style={{ color: "#444", fontSize: "8px" }}>4 HRS</span></div>
                            <div className="activity-type" style={{ background: `${track.color}15`, color: track.color, border: `1px solid ${track.color}33` }}>{w.weekend.label.toUpperCase()}</div>
                            <div className="activity-content">{w.weekend.content}</div>
                          </div>
                          {hasProject && (
                            <div className="project-box" style={{ borderColor: track.color, background: `${track.color}08` }}>
                              <div className="project-box-label" style={{ color: track.color }}>◆ PROJECT</div>
                              <div className="project-box-text">{w.project}</div>
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  );
}
